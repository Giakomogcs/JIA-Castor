      "parameters": {
        "jsCode": "const it = $input.first() && $input.first().json || {};\nconst raw = it.error || it.message || (it.error && it.error.message) || '';\nlet msg = String(raw || '').trim();\nif (!msg) msg = 'Erro inesperado no banco';\n// Detecta causas comuns para mensagem mais util ao admin\nconst low = msg.toLowerCase();\nlet hint = '';\nif (low.includes('function') && low.includes('does not exist')) {\n  hint = ' (migration 020/021 nao aplicada ou cache pgrst desatualizado â€” rode: NOTIFY pgrst, \\'reload schema\\';)';\n} else if (low.includes('apenas admin') || low.includes('admin') && low.includes('autoriz')) {\n  hint = ' (caller nao e admin â€” confira role no metadata do usuario)';\n} else if (low.includes('relation') && low.includes('does not exist')) {\n  hint = ' (tabela/view ausente â€” confira migrations 010/015/019)';\n}\nreturn [{ json: { ok:false, data:null, error: msg + hint } }];"
